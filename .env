# .env.example
# Copy this file to .env and fill in the values.

# --- LLM Configuration (Ollama) ---
# # The base URL for your local Ollama instance
# OLLAMA_BASE_URL="http://localhost:11434"
# # The model tag for Llama 3 as pulled in Ollama
# LLM_MODEL_NAME="llama3:8b"

# --- Embedding Model Configuration (Hugging Face) ---
# This model runs locally to create embeddings for your documents.
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"

# --- Vector Store and RAG Configuration ---
DOCS_DIRECTORY="docs"
VECTOR_STORE_DIRECTORY="vector_store"
K_RETRIEVED_DOCS=4
MAX_TOKENS_GENERATED=1024 # Llama3 can handle larger contexts

# --- Text Splitting ---
CHUNK_SIZE=256
CHUNK_OVERLAP=40

# --- Email Service (Optional) ---
# To enable sending emails for lead capture, fill these out.
# Otherwise, leads will just be printed to the console.
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="abhiram.kaitoz@gmail.com"
SMTP_PASSWORD="ptnw aohw buiy qmqo"
EMAIL_SENDER_ADDRESS="abhiram.kaitoz@gmail.com"
EMAIL_RECIPIENT_ADDRESS="abhiramabh9544@gmail.com"

# --- OpenRouter Settings ---
OPENROUTER_API_KEY = "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"
OPENROUTER_BASE_URL = "https://openrouter.ai/api/v1"

# Choose any model from OpenRouter's list
LLM_MODEL_NAME = "anthropic/claude-3-haiku" 